{
  "name": "@grupodiariodaregiao/bunstone",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./*": {
      "import": "./dist/*.js",
      "types": "./dist/*.d.ts"
    }
  },
  "version": "1.0.0",
  "homepage": "https://bunstone.diario.one/",
  "repository": {
    "url": "https://github.com/diariodaregiao/bunstone.git",
    "type": "git"
  },
  "type": "module",
  "bin": {
    "bunstone": "./bin/cli.ts"
  },
  "files": [
    "dist",
    "bin",
    "src",
    "tsconfig.json",
    "docs/**/*.md",
    "README.md",
    "AGENTS.md",
    "CLAUDE.md",
    "llms.txt",
    "MIGRATION.md"
  ],
  "scripts": {
    "agents:build": "bun run ./scripts/generate-agents.ts",
    "test": "bun test",
    "coverage": "bun test --coverage",
    "typecheck": "tsc --noEmit",
    "build": "rm -rf dist && bun build ./index.ts --outdir ./dist --target bun --packages external && tsc -p tsconfig.build.json --emitDeclarationOnly --declaration --outDir dist && tsc-alias -p tsconfig.build.json --outDir dist",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format . --write",
    "check": "tsc --noEmit && biome check . && bun test",
    "benchmark": "bun run ./benchmarks/run.ts",
    "prepack": "npm run build && npm run agents:build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@types/amqplib": "^0.10.8",
    "@types/autocannon": "^7.12.7",
    "@types/bun": "latest",
    "autocannon": "^8.0.0",
    "bun-types": "1.3.11",
    "tsc-alias": "^1.9.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/context-async-hooks": "^2.7.1",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.217.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.217.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-metrics": "^2.7.1",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "amqplib": "^0.10.4",
    "jose": "^6.2.3",
    "reflect-metadata": "^0.2.2",
    "zod": "^4.3.2"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "packageManager": "bun@1.1.0"
}
